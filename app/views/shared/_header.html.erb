<header class="flex justify-between items-center py-4 md:py-8">
  <!-- logo - start -->
  <%= link_to root_path, class: "title inline-flex items-center text-black-800 text-2xl md:text-3xl font-bold gap-2.5" do %>
    <%= image_tag 'children_crossing.png', alt: t('defaults.site'), class: 'h-12 w-12 cursor-pointer mx-2' %>
    <%= t 'records.new.title' %>
  <% end %>

  <!-- logo - end -->

  <!-- nav - start -->
  <nav class="flex gap-3 md:gap-6">
    <% { en: 'EN', zh: '中', ja: 'JP' }.each do |loc, label| %>
      <% if I18n.locale == loc %>
        <span class="text-indigo-600 text-sm md:text-lg font-bold border-b-2 border-indigo-500 pb-1"><%= label %></span>
      <% else %>
        <%= link_to label, url_for(locale: loc), class: "text-gray-500 hover:text-indigo-500 text-sm md:text-lg font-semibold transition duration-100" %>
      <% end %>
    <% end %>
  </nav>
  <!-- nav - end -->
</header>