<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <!-- ogp -->
    <%= display_meta_tags(default_meta_tags) %>

    <title><%= full_title(yield(:title)) %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#6366f1">
    <link rel="manifest" href="/manifest.json">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= render 'shared/json_ld' %>

    <%= stylesheet_link_tag 'tailwind', media: 'all', 'data-turbo-track': 'reload' %>
    <%= javascript_importmap_tags %>
    <% if ENV['GA_TRACKING_ID'].present? %>
    <!-- Global site tag (gtag.js) - Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=<%= ENV['GA_TRACKING_ID'] %>" nonce="<%= content_security_policy_nonce %>"></script>
    <script nonce="<%= content_security_policy_nonce %>">
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', '<%= ENV['GA_TRACKING_ID'] %>');
    </script>
    <% end %>
  </head>

  <body>
  <div class="bg-white pb-6 sm:pb-8 lg:pb-12">
    <div class="max-w-screen-2xl px-4 md:px-8 mx-auto">
      <%= render 'shared/header' %>
      <%= yield %>
    </div>
  </div>
  <%= render 'shared/footer' %>
  <script nonce="<%= content_security_policy_nonce %>">
  (function() {
    var scrollBtn = document.getElementById('scroll-down');
    if (scrollBtn) {
      scrollBtn.addEventListener('click', function() {
        var form = document.getElementById('form');
        if (form) {
          form.scrollIntoView({ behavior: "smooth", block: "start", inline: "start" });
        }
      });
    }
  })();
  </script>
  </body>
</html>